---
import BaseLayout from './BaseLayout.astro';
import FAQ from '../components/FAQ.astro';
import RelatedTools from '../components/RelatedTools.astro';
import type { FAQItem } from '../components/FAQ.astro';
import type { Tool } from '../data/tools';

interface Props {
  title: string;
  titleEn?: string;
  description: string;
  descriptionEn?: string;
  category: string;
  categoryEn?: string;
  faqs?: FAQItem[];
  relatedTools?: Tool[];
  howToSteps?: string[];
  howToStepsEn?: string[];
  applicationCategory?: string;
  operatingSystem?: string;
}

const {
  title,
  titleEn,
  description,
  descriptionEn,
  category,
  categoryEn,
  faqs = [],
  relatedTools = [],
  howToSteps = [],
  howToStepsEn = [],
  applicationCategory = 'UtilitiesApplication',
  operatingSystem = 'Web Browser',
} = Astro.props;

const schemaJson = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: title,
  description,
  applicationCategory,
  operatingSystem,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'TWD',
  },
});
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schemaJson} />
  </Fragment>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-12">

    <!-- 麵包屑 -->
    <nav aria-label="breadcrumb" class="text-sm text-gray-500">
      <ol class="flex items-center gap-1.5">
        <li>
          <a href="/" class="hover:text-blue-600 transition-colors">
            <span class="lang-zh">首頁</span>
            <span class="lang-en">Home</span>
          </a>
        </li>
        <li aria-hidden="true" class="text-gray-300">/</li>
        <li class="text-gray-400">
          <span class="lang-zh">{category}</span>
          <span class="lang-en">{categoryEn ?? category}</span>
        </li>
        <li aria-hidden="true" class="text-gray-300">/</li>
        <li class="text-gray-800 font-medium" aria-current="page">
          <span class="lang-zh">{title}</span>
          <span class="lang-en">{titleEn ?? title}</span>
        </li>
      </ol>
    </nav>

    <!-- 工具標題區 -->
    <div class="space-y-3">
      <h1 class="text-3xl font-bold text-gray-900">
        <span class="lang-zh">{title}</span>
        <span class="lang-en">{titleEn ?? title}</span>
      </h1>
      <p class="text-gray-600 leading-relaxed">
        <span class="lang-zh">{description}</span>
        <span class="lang-en">{descriptionEn ?? description}</span>
      </p>

      <div class="inline-flex items-center gap-2 bg-emerald-50 border border-emerald-200 text-emerald-700 rounded-full px-4 py-1.5 text-sm font-medium">
        <span>🔒</span>
        <span>
          <span class="lang-zh">100% 瀏覽器處理 — 您的檔案不會上傳至任何伺服器</span>
          <span class="lang-en">100% Browser-side — your files never leave your device</span>
        </span>
      </div>
    </div>

    <!-- 工具主體 -->
    <div>
      <slot />
    </div>

    <!-- 如何使用 -->
    {howToSteps.length > 0 && (
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-5">
          <span class="lang-zh">如何使用</span>
          <span class="lang-en">How to Use</span>
        </h2>
        <ol class="space-y-3">
          {howToSteps.map((step, i) => {
            const stepEn = howToStepsEn[i];
            return (
              <li class="flex items-start gap-4">
                <span class="flex-shrink-0 w-8 h-8 rounded-full bg-blue-600 text-white text-sm font-bold flex items-center justify-center">
                  {i + 1}
                </span>
                <span class="text-gray-700 leading-relaxed pt-1">
                  <span class="lang-zh">{step}</span>
                  <span class="lang-en">{stepEn ?? step}</span>
                </span>
              </li>
            );
          })}
        </ol>
      </section>
    )}

    <!-- 常見問題 -->
    {faqs.length > 0 && (
      <FAQ items={faqs} />
    )}

    <!-- 相關工具 -->
    {relatedTools.length > 0 && (
      <RelatedTools tools={relatedTools} />
    )}

  </div>
</BaseLayout>

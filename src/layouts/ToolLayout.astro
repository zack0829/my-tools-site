---
import BaseLayout from './BaseLayout.astro';
import FAQ from '../components/FAQ.astro';
import RelatedTools from '../components/RelatedTools.astro';
import type { FAQItem } from '../components/FAQ.astro';
import type { Tool } from '../data/tools';

interface Props {
  /** 工具名稱（用於頁面標題與麵包屑） */
  title: string;
  /** 工具描述（用於 meta description） */
  description: string;
  /** 工具分類（用於麵包屑） */
  category: string;
  /** 常見問題列表 */
  faqs?: FAQItem[];
  /** 相關工具列表 */
  relatedTools?: Tool[];
  /** 如何使用步驟（可選，字串陣列） */
  howToSteps?: string[];
  /** SoftwareApplication schema 用：應用程式類別 */
  applicationCategory?: string;
  /** SoftwareApplication schema 用：操作系統 */
  operatingSystem?: string;
}

const {
  title,
  description,
  category,
  faqs = [],
  relatedTools = [],
  howToSteps = [],
  applicationCategory = 'UtilitiesApplication',
  operatingSystem = 'Web Browser',
} = Astro.props;

// SoftwareApplication 結構化資料（預留，工具頁傳入資料後即生效）
const schemaJson = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: title,
  description,
  applicationCategory,
  operatingSystem,
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'TWD',
  },
});
---

<BaseLayout title={title} description={description}>
  <!-- 注入結構化資料 -->
  <Fragment slot="head">
    <script type="application/ld+json" set:html={schemaJson} />
  </Fragment>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-12">

    <!-- 麵包屑 -->
    <nav aria-label="麵包屑" class="text-sm text-gray-500">
      <ol class="flex items-center gap-1.5">
        <li><a href="/" class="hover:text-blue-600 transition-colors">首頁</a></li>
        <li aria-hidden="true" class="text-gray-300">/</li>
        <li class="text-gray-400">{category}</li>
        <li aria-hidden="true" class="text-gray-300">/</li>
        <li class="text-gray-800 font-medium" aria-current="page">{title}</li>
      </ol>
    </nav>

    <!-- 工具標題區 -->
    <div class="space-y-3">
      <h1 class="text-3xl font-bold text-gray-900">{title}</h1>
      <p class="text-gray-600 leading-relaxed">{description}</p>

      <!-- 隱私標示 badge -->
      <div class="inline-flex items-center gap-2 bg-emerald-50 border border-emerald-200 text-emerald-700 rounded-full px-4 py-1.5 text-sm font-medium">
        <span>🔒</span>
        <span>100% 瀏覽器處理 — 您的檔案不會上傳至任何伺服器</span>
      </div>
    </div>

    <!-- 工具主體（由各工具頁面填入） -->
    <div>
      <slot />
    </div>

    <!-- 如何使用 -->
    {howToSteps.length > 0 && (
      <section>
        <h2 class="text-2xl font-bold text-gray-900 mb-5">如何使用</h2>
        <ol class="space-y-3">
          {howToSteps.map((step, i) => (
            <li class="flex items-start gap-4">
              <span class="flex-shrink-0 w-8 h-8 rounded-full bg-blue-600 text-white text-sm font-bold flex items-center justify-center">
                {i + 1}
              </span>
              <span class="text-gray-700 leading-relaxed pt-1">{step}</span>
            </li>
          ))}
        </ol>
      </section>
    )}

    <!-- 常見問題 -->
    {faqs.length > 0 && (
      <FAQ items={faqs} />
    )}

    <!-- 相關工具 -->
    {relatedTools.length > 0 && (
      <RelatedTools tools={relatedTools} />
    )}

  </div>
</BaseLayout>

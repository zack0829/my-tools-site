---
import ToolLayout from '../../layouts/ToolLayout.astro';
import FileDropZone from '../../components/FileDropZone.astro';
import { tools } from '../../data/tools';
import type { FAQItem } from '../../components/FAQ.astro';

const relatedSlugs = ['png-to-jpg', 'jpg-to-png', 'webp-converter'];
const relatedTools = tools.filter((t) => relatedSlugs.includes(t.slug));

const faqs: FAQItem[] = [
  {
    question: '圖片壓縮會破壞畫質嗎？',
    questionEn: 'Will compression damage image quality?',
    answer: 'JPG 和 WebP 是有損壓縮，壓縮後畫質確實會略降，但在品質 75 以上，人眼通常看不出明顯差異。PNG 壓縮則是無損的，只縮小檔案大小，不影響畫質。',
    answerEn: 'JPG and WebP use lossy compression, so quality does drop slightly. However, above quality 75, the difference is usually invisible to the naked eye. PNG compression is lossless — it only reduces file size without any quality loss.',
  },
  {
    question: '品質設多少最適合？',
    questionEn: 'What quality setting should I use?',
    answer: '預設的 80 對大多數用途都很合適，網頁圖片、社群媒體發文等場合都足夠。如果是需要印刷或高細節呈現的圖片，可以拉到 90 以上。低於 60 才會開始出現明顯的色塊或模糊。',
    answerEn: 'The default of 80 is suitable for most uses — web images, social media, etc. For print or high-detail work, push it to 90+. Below 60 is where noticeable artifacts start to appear.',
  },
  {
    question: '為什麼有時候壓縮後反而變大？',
    questionEn: 'Why is the compressed file sometimes larger?',
    answer: '有些圖片本身已經是高度壓縮過的狀態，再壓一次反而可能讓工具為了保留品質而產生更大的檔案。這種情況下直接使用原始檔案就好，結果卡片也會標示「原檔已最佳化」讓你知道。',
    answerEn: 'Some images are already heavily compressed. Re-compressing them can result in a larger file as the encoder works to preserve quality. In this case the result card shows "Already Optimized" and the original file is returned.',
  },
  {
    question: '我的圖片會上傳到伺服器嗎？',
    questionEn: 'Will my images be uploaded to a server?',
    answer: '完全不會。所有壓縮都在你的瀏覽器裡完成，圖片從來不會離開你的裝置。就算網路斷線，這個工具也能正常運作。',
    answerEn: 'Not at all. All compression runs inside your browser. Your images never leave your device, even when offline.',
  },
  {
    question: '為什麼這個工具是免費的？',
    questionEn: 'Why is this tool free?',
    answer: '因為所有運算都在你的瀏覽器裡發生，伺服器不需要做任何處理，所以幾乎沒有運算成本。工具本身就是這樣能免費提供的原因，不需要你登入或付費。',
    answerEn: 'Because all processing happens in your browser — the server does nothing. With virtually no compute costs, we can offer the tool completely free, no login or payment required.',
  },
];

const howToSteps = [
  '上傳圖片：支援 JPG、PNG、WebP 三種格式，可一次選擇多張批次處理。',
  '調整壓縮設定：拖動品質滑桿（80 通常是品質與大小最佳平衡點），可選擇限制最大寬度進一步縮小檔案。',
  '下載壓縮結果：單張下載或一鍵打包成 ZIP，所有處理都在您的瀏覽器完成。',
];
const howToStepsEn = [
  'Upload images: supports JPG, PNG, and WebP. Select multiple files for batch processing.',
  'Adjust settings: drag the quality slider (80 is usually the sweet spot), optionally set a max width to further reduce file size.',
  'Download results: save individual files or download all as a ZIP — all processed in your browser.',
];
---

<ToolLayout
  title="圖片壓縮線上工具 - 免費批次壓縮 JPG/PNG/WebP"
  titleEn="Image Compressor — Free Online Batch Compression"
  description="100% 瀏覽器處理的圖片壓縮工具，支援 JPG、PNG、WebP 批次壓縮，可調品質與尺寸，檔案不上傳保護隱私。"
  descriptionEn="Free browser-side image compressor. Batch compress JPG, PNG, and WebP with adjustable quality and max-width. No upload, full privacy."
  category="圖片工具"
  categoryEn="Image Tools"
  faqs={faqs}
  relatedTools={relatedTools}
  howToSteps={howToSteps}
  howToStepsEn={howToStepsEn}
  applicationCategory="UtilitiesApplication"
  operatingSystem="Web Browser"
>
  <div class="space-y-6">
    <div class="bg-white rounded-2xl border border-gray-200 p-6 space-y-5">
      <h2 class="text-lg font-semibold text-gray-900">
        <span class="lang-zh">壓縮設定</span>
        <span class="lang-en">Compression Settings</span>
      </h2>

      <!-- 品質滑桿 -->
      <div class="space-y-2">
        <div class="flex items-center justify-between">
          <label for="quality-slider" class="text-sm font-medium text-gray-700">
            <span class="lang-zh">壓縮品質</span>
            <span class="lang-en">Quality</span>
          </label>
          <span id="quality-display" class="text-sm font-bold text-blue-600">80</span>
        </div>
        <input id="quality-slider" type="range" min="1" max="100" value="80" class="w-full h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-blue-600" />
        <div class="flex justify-between text-xs text-gray-400">
          <span><span class="lang-zh">1（最小）</span><span class="lang-en">1 (smallest)</span></span>
          <span><span class="lang-zh">100（最高品質）</span><span class="lang-en">100 (best quality)</span></span>
        </div>
      </div>

      <!-- 最大寬度限制 -->
      <div class="space-y-3">
        <label class="flex items-center gap-2 cursor-pointer">
          <input id="max-width-toggle" type="checkbox" class="h-4 w-4 rounded border-gray-300 text-blue-600 accent-blue-600 cursor-pointer" />
          <span class="text-sm font-medium text-gray-700">
            <span class="lang-zh">限制最大寬度</span>
            <span class="lang-en">Limit Max Width</span>
          </span>
        </label>
        <div id="max-width-options" class="hidden flex flex-wrap gap-2 pl-6">
          <button class="max-width-btn px-3 py-1.5 rounded-lg border-2 border-blue-500 bg-white text-sm font-medium text-gray-700 transition-all" data-width="1920">1920 px</button>
          <button class="max-width-btn px-3 py-1.5 rounded-lg border-2 border-transparent bg-gray-100 text-sm font-medium text-gray-700 transition-all" data-width="1280">1280 px</button>
          <button class="max-width-btn px-3 py-1.5 rounded-lg border-2 border-transparent bg-gray-100 text-sm font-medium text-gray-700 transition-all" data-width="800">800 px</button>
          <div class="flex items-center gap-2">
            <button id="custom-width-btn" class="max-width-btn px-3 py-1.5 rounded-lg border-2 border-transparent bg-gray-100 text-sm font-medium text-gray-700 transition-all" data-width="custom">
              <span class="lang-zh">自訂</span><span class="lang-en">Custom</span>
            </button>
            <input id="custom-width-input" type="number" min="100" max="9999" placeholder="px" class="hidden w-20 text-sm border border-gray-300 rounded-lg px-2 py-1.5 focus:outline-none focus:ring-2 focus:ring-blue-500" />
          </div>
        </div>
      </div>

      <!-- 輸出格式 -->
      <div class="space-y-2">
        <label class="text-sm font-medium text-gray-700">
          <span class="lang-zh">輸出格式</span>
          <span class="lang-en">Output Format</span>
        </label>
        <div class="flex flex-wrap gap-2">
          <button class="format-btn px-4 py-2 rounded-lg border-2 border-blue-500 text-sm font-medium transition-all" data-format="original">
            <span class="lang-zh">保持原格式</span><span class="lang-en">Keep Original</span>
          </button>
          <button class="format-btn px-4 py-2 rounded-lg border-2 border-transparent bg-gray-100 text-sm font-medium transition-all" data-format="image/jpeg">
            <span class="lang-zh">強制 JPG</span><span class="lang-en">Force JPG</span>
          </button>
          <button class="format-btn px-4 py-2 rounded-lg border-2 border-transparent bg-gray-100 text-sm font-medium transition-all" data-format="image/webp">
            <span class="lang-zh">強制 WebP</span><span class="lang-en">Force WebP</span>
          </button>
        </div>
      </div>
    </div>

    <FileDropZone
      accept="image/jpeg,image/png,image/webp"
      multiple={true}
      maxSizeMB={50}
      hint="拖放圖片到此處，或點擊選擇（JPG / PNG / WebP，最多 30 張）"
      hintEn="Drag & drop images here, or click to select (JPG / PNG / WebP, up to 30)"
      inputId="image-file-input"
    />

    <div id="error-banner" class="hidden flex items-center gap-3 bg-red-50 border border-red-200 text-red-700 rounded-xl px-5 py-3 text-sm">
      <span class="text-lg shrink-0">⚠️</span>
      <span id="error-text"></span>
    </div>

    <div id="progress-section" class="hidden space-y-2">
      <div class="flex items-center justify-between text-sm text-gray-600">
        <span><span class="lang-zh">壓縮中...</span><span class="lang-en">Compressing...</span></span>
        <span id="progress-text">0 / 0</span>
      </div>
      <div class="w-full h-2 bg-gray-200 rounded-full overflow-hidden">
        <div id="progress-bar" class="h-full bg-blue-600 rounded-full transition-all duration-300" style="width:0%"></div>
      </div>
    </div>

    <div id="results-section" class="hidden space-y-4">
      <div class="flex items-center justify-between">
        <h2 class="text-lg font-semibold text-gray-900">
          <span class="lang-zh">壓縮結果</span>
          <span class="lang-en">Results</span>
        </h2>
        <div class="flex gap-2">
          <button id="download-all-btn" class="hidden flex items-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors">
            <span>⬇️</span>
            <span class="lang-zh">全部下載 ZIP</span><span class="lang-en">Download All ZIP</span>
          </button>
          <button id="clear-btn" class="flex items-center gap-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium px-4 py-2 rounded-lg transition-colors">
            <span>🗑️</span>
            <span class="lang-zh">清除全部</span><span class="lang-en">Clear All</span>
          </button>
        </div>
      </div>
      <div id="results-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4"></div>
    </div>
  </div>
</ToolLayout>

<script>
  import imageCompression from 'browser-image-compression';
  import { zipSync } from 'fflate';

  const t = (zh: string, en: string) => document.documentElement.lang === 'en' ? en : zh;

  let quality = 80;
  let maxWidthEnabled = false;
  let maxWidth = 1920;
  let customWidthActive = false;
  let outputFormat: string = 'original';

  interface CompressedFile {
    name: string; outputName: string; blob: Blob; originalFile: File;
    originalSize: number; compressedSize: number; thumbUrl: string; enlarged: boolean;
  }
  const compressedFiles: CompressedFile[] = [];

  const qualitySlider = document.getElementById('quality-slider') as HTMLInputElement;
  const qualityDisplay = document.getElementById('quality-display') as HTMLSpanElement;
  const maxWidthToggle = document.getElementById('max-width-toggle') as HTMLInputElement;
  const maxWidthOptions = document.getElementById('max-width-options') as HTMLDivElement;
  const maxWidthBtns = document.querySelectorAll<HTMLButtonElement>('.max-width-btn');
  const customWidthBtn = document.getElementById('custom-width-btn') as HTMLButtonElement;
  const customWidthInput = document.getElementById('custom-width-input') as HTMLInputElement;
  const formatBtns = document.querySelectorAll<HTMLButtonElement>('.format-btn');
  const errorBanner = document.getElementById('error-banner') as HTMLDivElement;
  const errorText = document.getElementById('error-text') as HTMLSpanElement;
  const progressSection = document.getElementById('progress-section') as HTMLDivElement;
  const progressBar = document.getElementById('progress-bar') as HTMLDivElement;
  const progressText = document.getElementById('progress-text') as HTMLSpanElement;
  const resultsSection = document.getElementById('results-section') as HTMLDivElement;
  const resultsGrid = document.getElementById('results-grid') as HTMLDivElement;
  const downloadAllBtn = document.getElementById('download-all-btn') as HTMLButtonElement;
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;

  qualitySlider.addEventListener('input', () => { quality = Number(qualitySlider.value); qualityDisplay.textContent = String(quality); });

  maxWidthToggle.addEventListener('change', () => { maxWidthEnabled = maxWidthToggle.checked; maxWidthOptions.classList.toggle('hidden', !maxWidthEnabled); });

  function selectMaxWidth(btn: HTMLButtonElement) {
    maxWidthBtns.forEach((b) => {
      b.classList.toggle('border-blue-500', b === btn); b.classList.toggle('border-transparent', b !== btn);
      b.classList.toggle('bg-gray-100', b !== btn); b.classList.toggle('bg-white', b === btn);
    });
  }
  maxWidthBtns.forEach((btn) => {
    if (btn.id === 'custom-width-btn') return;
    btn.addEventListener('click', () => { customWidthActive = false; maxWidth = Number(btn.dataset.width); customWidthInput.classList.add('hidden'); selectMaxWidth(btn); });
  });
  customWidthBtn.addEventListener('click', () => { customWidthActive = true; customWidthInput.classList.remove('hidden'); customWidthInput.focus(); selectMaxWidth(customWidthBtn); });
  customWidthInput.addEventListener('input', () => { const v = Number(customWidthInput.value); if (v >= 100 && v <= 9999) maxWidth = v; });

  formatBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      outputFormat = btn.dataset.format!;
      formatBtns.forEach((b) => { b.classList.toggle('border-blue-500', b === btn); b.classList.toggle('border-transparent', b !== btn); b.classList.toggle('bg-gray-100', b !== btn); });
    });
  });

  function showError(msg: string) { errorText.textContent = msg; errorBanner.classList.remove('hidden'); setTimeout(() => errorBanner.classList.add('hidden'), 5000); }
  function formatSize(bytes: number): string {
    if (bytes < 1024) return `${bytes} B`;
    if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
    return `${(bytes / 1024 / 1024).toFixed(2)} MB`;
  }
  function getOutputName(file: File): string {
    const base = file.name.replace(/\.[^.]+$/, '');
    if (outputFormat === 'image/jpeg') return `${base}.jpg`;
    if (outputFormat === 'image/webp') return `${base}.webp`;
    return file.name;
  }
  function getMimeType(file: File): string { return outputFormat !== 'original' ? outputFormat : (file.type || 'image/jpeg'); }

  function addResultCard(item: CompressedFile) {
    const ratio = (((item.originalSize - item.compressedSize) / item.originalSize) * 100).toFixed(1);
    const saved = Number(ratio) > 0;
    const sizeRow = item.enlarged
      ? `<div class="flex justify-between font-medium text-orange-500"><span><span class="lang-zh">原檔已最佳化</span><span class="lang-en">Already Optimized</span></span><span>+${Math.abs(Number(ratio))}%</span></div>`
      : `<div class="flex justify-between font-medium ${saved ? 'text-emerald-600' : 'text-orange-500'}"><span>${saved ? `<span class="lang-zh">節省</span><span class="lang-en">Saved</span>` : `<span class="lang-zh">增加</span><span class="lang-en">Increased</span>`}</span><span>${saved ? '-' : '+'}${Math.abs(Number(ratio))}%</span></div>`;
    const card = document.createElement('div');
    card.className = 'bg-white rounded-xl border border-gray-200 overflow-hidden flex flex-col';
    card.innerHTML = `
      <div class="aspect-video bg-gray-100 flex items-center justify-center overflow-hidden">
        <img src="${item.thumbUrl}" alt="${item.outputName}" class="max-h-full max-w-full object-contain" loading="lazy" />
      </div>
      <div class="p-4 flex flex-col gap-3 flex-1">
        <p class="text-sm font-medium text-gray-900 truncate">${item.outputName}</p>
        <div class="text-xs text-gray-500 space-y-1">
          <div class="flex justify-between"><span><span class="lang-zh">原始大小</span><span class="lang-en">Original</span></span><span>${formatSize(item.originalSize)}</span></div>
          <div class="flex justify-between"><span><span class="lang-zh">壓縮後</span><span class="lang-en">Compressed</span></span><span>${formatSize(item.compressedSize)}</span></div>
          ${sizeRow}
        </div>
        <button class="download-btn mt-auto w-full flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium py-2 rounded-lg transition-colors">
          <span>⬇️</span> <span class="lang-zh">下載</span><span class="lang-en">Download</span>
        </button>
      </div>
    `;
    card.querySelector<HTMLButtonElement>('.download-btn')!.addEventListener('click', () => {
      const f = item.enlarged ? item.originalFile : item.blob;
      const n = item.enlarged ? item.originalFile.name : item.outputName;
      const url = URL.createObjectURL(f); const a = document.createElement('a'); a.href = url; a.download = n; a.click(); URL.revokeObjectURL(url);
    });
    resultsGrid.appendChild(card);
  }

  async function processFiles(files: FileList | File[]) {
    const fileArray = Array.from(files);
    const ACCEPTED = ['image/jpeg', 'image/png', 'image/webp'];
    const validFiles = fileArray.filter((f) => ACCEPTED.includes(f.type));
    const invalid = fileArray.filter((f) => !ACCEPTED.includes(f.type));
    if (invalid.length > 0) showError(t(`${invalid.length} 個檔案格式不支援，已略過`, `${invalid.length} unsupported file(s) skipped`));
    if (validFiles.length === 0) return;
    if (validFiles.length > 30) { showError(t(`一次最多壓縮 30 張，已略過後面 ${validFiles.length - 30} 張`, `Max 30 files. ${validFiles.length - 30} skipped`)); validFiles.splice(30); }
    const tooBig = validFiles.filter((f) => f.size > 50 * 1024 * 1024);
    if (tooBig.length > 0) { showError(t('部分檔案超過 50 MB，已略過', 'Some files exceed 50 MB and were skipped')); validFiles.splice(0, validFiles.length, ...validFiles.filter((f) => f.size <= 50 * 1024 * 1024)); }
    if (validFiles.length === 0) return;

    compressedFiles.length = 0; resultsGrid.innerHTML = '';
    resultsSection.classList.remove('hidden'); downloadAllBtn.classList.add('hidden'); progressSection.classList.remove('hidden');
    let done = 0; progressText.textContent = `0 / ${validFiles.length}`; progressBar.style.width = '0%';

    for (const file of validFiles) {
      try {
        const mime = getMimeType(file);
        const options: Parameters<typeof imageCompression>[1] = {
          initialQuality: quality / 100, fileType: mime, useWebWorker: true,
          ...(maxWidthEnabled ? { maxWidthOrHeight: maxWidth } : {}),
        };
        const compressed = await imageCompression(file, options);
        const enlarged = compressed.size > file.size;
        const finalBlob = enlarged ? file : compressed;
        const thumbUrl = await new Promise<string>((res) => { const r = new FileReader(); r.onload = (e) => res(e.target!.result as string); r.readAsDataURL(finalBlob); });
        const item: CompressedFile = { name: file.name, outputName: getOutputName(file), blob: finalBlob, originalFile: file, originalSize: file.size, compressedSize: compressed.size, thumbUrl, enlarged };
        compressedFiles.push(item); addResultCard(item);
      } catch { showError(t(`${file.name} 壓縮失敗`, `${file.name} compression failed`)); }
      done++;
      progressBar.style.width = `${Math.round((done / validFiles.length) * 100)}%`;
      progressText.textContent = `${done} / ${validFiles.length}`;
    }
    progressSection.classList.add('hidden');
    if (compressedFiles.length > 1) downloadAllBtn.classList.remove('hidden');
  }

  document.addEventListener('files-selected', (e: Event) => processFiles((e as CustomEvent<FileList>).detail));

  downloadAllBtn.addEventListener('click', async () => {
    downloadAllBtn.disabled = true; downloadAllBtn.textContent = t('打包中...', 'Packing...');
    try {
      const fileMap: Record<string, Uint8Array> = {};
      await Promise.all(compressedFiles.map(async (item) => {
        const f = item.enlarged ? item.originalFile : item.blob;
        const n = item.enlarged ? item.originalFile.name : item.outputName;
        fileMap[n] = new Uint8Array(await f.arrayBuffer());
      }));
      const url = URL.createObjectURL(new Blob([zipSync(fileMap, { level: 0 })], { type: 'application/zip' }));
      const a = document.createElement('a'); a.href = url; a.download = 'compressed-images.zip'; a.click(); URL.revokeObjectURL(url);
    } finally { downloadAllBtn.disabled = false; downloadAllBtn.innerHTML = `<span>⬇️</span> <span class="lang-zh">全部下載 ZIP</span><span class="lang-en">Download All ZIP</span>`; }
  });

  clearBtn.addEventListener('click', () => {
    compressedFiles.length = 0; resultsGrid.innerHTML = '';
    resultsSection.classList.add('hidden'); downloadAllBtn.classList.add('hidden');
    progressSection.classList.add('hidden'); errorBanner.classList.add('hidden');
    const fi = document.getElementById('image-file-input') as HTMLInputElement; if (fi) fi.value = '';
    const fl = document.getElementById('file-list'); if (fl) { fl.innerHTML = ''; fl.classList.add('hidden'); }
  });
</script>

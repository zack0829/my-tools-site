---
import ToolLayout from '../../layouts/ToolLayout.astro';
import { tools } from '../../data/tools';
import type { FAQItem } from '../../components/FAQ.astro';

const relatedSlugs = ['pdf-split', 'png-to-jpg', 'image-compressor'];
const relatedTools = tools.filter((t) => relatedSlugs.includes(t.slug));

const faqs: FAQItem[] = [
  {
    question: '我的 PDF 會上傳到伺服器嗎？',
    answer:
      '完全不會。所有處理都在你的瀏覽器裡完成，PDF 檔案從來不會離開你的裝置。就算網路斷線，這個工具也能正常運作。',
  },
  {
    question: '一次最多可以合併幾個 PDF？',
    answer:
      '一次最多合併 20 個 PDF，每個檔案上限 100 MB。如果你的需求超過這個限制，可以分批合併再重複操作。',
  },
  {
    question: '合併後的 PDF 會不會變大？',
    answer:
      '合併後的大小基本上是所有原始檔案的加總。如果勾選「壓縮輸出」，pdf-lib 會啟用物件流壓縮，通常可以讓檔案略小一些，但效果因原始 PDF 內容而異。',
  },
  {
    question: '為什麼有「壓縮輸出」選項？',
    answer:
      '「壓縮輸出」會啟用 PDF 的物件流（Object Streams）壓縮，適合想縮小最終檔案的情況。預設關閉是因為壓縮需要額外運算時間，處理大型 PDF 時會比較慢。',
  },
  {
    question: '為什麼這個工具是免費的？',
    answer:
      '因為所有運算都在你的瀏覽器裡發生，伺服器不需要做任何處理，幾乎沒有運算成本。工具本身就是這樣能免費提供的原因，不需要你登入或付費。',
  },
];

const howToSteps = [
  '上傳 PDF：拖放或點擊上傳，可一次選擇多個 PDF 檔案。',
  '調整順序：在清單上拖曳檔案改變合併順序，可隨時移除不要的檔案。',
  '開始合併：點擊「開始合併」按鈕後即可下載合併好的 PDF。',
];
---

<ToolLayout
  title="PDF 合併線上工具 - 免費批次合併 PDF 不上傳"
  description="100% 瀏覽器處理的 PDF 合併工具，支援拖曳排序、批次合併多個 PDF 為一份檔案，檔案不上傳保護隱私。"
  category="PDF 工具"
  faqs={faqs}
  relatedTools={relatedTools}
  howToSteps={howToSteps}
  applicationCategory="UtilitiesApplication"
  operatingSystem="Web Browser"
>
  <div class="space-y-6">
    <!-- 設定區 -->
    <div class="bg-white rounded-2xl border border-gray-200 p-6 space-y-4">
      <h2 class="text-lg font-semibold text-gray-900">合併設定</h2>
      <label class="flex items-center gap-3 cursor-pointer select-none">
        <input
          id="compress-checkbox"
          type="checkbox"
          class="w-4 h-4 accent-blue-600 cursor-pointer"
        />
        <span class="text-sm font-medium text-gray-700">壓縮輸出 PDF（啟用物件流壓縮，可略微縮小檔案）</span>
      </label>
    </div>

    <!-- 上傳區 -->
    <div
      id="dropzone"
      class="relative flex flex-col items-center justify-center gap-4 w-full min-h-48 rounded-2xl border-2 border-dashed border-blue-300 bg-blue-50 hover:bg-blue-100 hover:border-blue-400 transition-colors cursor-pointer p-8 text-center"
      role="button"
      tabindex="0"
      aria-label="PDF 上傳區域"
    >
      <div class="flex flex-col items-center gap-2 pointer-events-none">
        <span class="text-5xl">📄</span>
        <p class="text-base font-medium text-blue-700">拖放 PDF 到此處，或點擊選擇（最多 20 個，每個最大 100 MB）</p>
        <p class="text-sm text-gray-500">支援多個 PDF 同時上傳</p>
      </div>
      <div class="flex items-center gap-1.5 text-xs text-emerald-700 bg-emerald-50 border border-emerald-200 rounded-full px-3 py-1 pointer-events-none">
        <span>🔒</span>
        <span>檔案僅在您的瀏覽器中處理，不會上傳至任何伺服器</span>
      </div>
      <input
        id="pdf-file-input"
        type="file"
        accept="application/pdf"
        multiple
        class="absolute inset-0 w-full h-full opacity-0 cursor-pointer"
        aria-hidden="true"
      />
    </div>

    <!-- 錯誤訊息 -->
    <div id="error-banner" class="hidden flex items-center gap-3 bg-red-50 border border-red-200 text-red-700 rounded-xl px-5 py-3 text-sm">
      <span class="text-lg shrink-0">⚠️</span>
      <span id="error-text"></span>
    </div>

    <!-- 檔案清單 -->
    <div id="file-list-section" class="hidden space-y-3">
      <div class="flex items-center justify-between">
        <h2 class="text-base font-semibold text-gray-900">已選擇的 PDF <span id="file-count" class="text-gray-400 font-normal text-sm"></span></h2>
        <p class="text-xs text-gray-400">拖曳列表項目可調整合併順序</p>
      </div>
      <ul id="file-list" class="space-y-2" aria-label="PDF 檔案列表"></ul>

      <!-- 操作按鈕 -->
      <div class="flex flex-wrap gap-3 pt-2">
        <button
          id="merge-btn"
          class="flex items-center gap-2 bg-blue-600 hover:bg-blue-700 disabled:bg-gray-300 disabled:cursor-not-allowed text-white text-sm font-semibold px-6 py-2.5 rounded-lg transition-colors"
        >
          <span>🔗</span>
          開始合併
        </button>
        <button
          id="clear-btn"
          class="flex items-center gap-2 bg-gray-100 hover:bg-gray-200 text-gray-700 text-sm font-medium px-4 py-2.5 rounded-lg transition-colors"
        >
          <span>🗑️</span>
          清除全部
        </button>
      </div>
    </div>

    <!-- 處理中 loading -->
    <div id="progress-section" class="hidden space-y-3">
      <div class="flex items-center gap-3 bg-blue-50 border border-blue-200 rounded-xl px-5 py-4">
        <div class="w-5 h-5 border-2 border-blue-600 border-t-transparent rounded-full animate-spin shrink-0"></div>
        <div>
          <p class="text-sm font-medium text-blue-700">合併中，請稍候...</p>
          <p class="text-xs text-blue-500">大型 PDF 可能需要 5–10 秒</p>
        </div>
      </div>
    </div>

    <!-- 結果區 -->
    <div id="result-section" class="hidden space-y-4">
      <h2 class="text-lg font-semibold text-gray-900">合併結果</h2>
      <div class="bg-white rounded-2xl border border-gray-200 p-6 space-y-4">
        <div class="grid grid-cols-2 gap-4 text-sm">
          <div class="bg-gray-50 rounded-xl p-4 text-center">
            <p class="text-gray-500 mb-1">總頁數</p>
            <p id="result-pages" class="text-2xl font-bold text-gray-900">—</p>
          </div>
          <div class="bg-gray-50 rounded-xl p-4 text-center">
            <p class="text-gray-500 mb-1">輸出大小</p>
            <p id="result-size" class="text-2xl font-bold text-gray-900">—</p>
          </div>
        </div>
        <button
          id="download-btn"
          class="w-full flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-xl transition-colors"
        >
          <span>⬇️</span>
          下載合併後的 PDF
        </button>
      </div>
    </div>
  </div>
</ToolLayout>

<script>
  import { PDFDocument } from 'pdf-lib';

  // ── 狀態 ─────────────────────────────────────────────────
  interface PdfEntry {
    file: File;
    pageCount: number;
    id: string;
  }

  let pdfEntries: PdfEntry[] = [];
  let mergedBlob: Blob | null = null;
  let dragSrcId: string | null = null;

  // ── DOM refs ────────────────────────────────────────────
  const dropzone = document.getElementById('dropzone') as HTMLDivElement;
  const fileInput = document.getElementById('pdf-file-input') as HTMLInputElement;
  const compressCheckbox = document.getElementById('compress-checkbox') as HTMLInputElement;
  const errorBanner = document.getElementById('error-banner') as HTMLDivElement;
  const errorText = document.getElementById('error-text') as HTMLSpanElement;
  const fileListSection = document.getElementById('file-list-section') as HTMLDivElement;
  const fileListEl = document.getElementById('file-list') as HTMLUListElement;
  const fileCount = document.getElementById('file-count') as HTMLSpanElement;
  const mergeBtn = document.getElementById('merge-btn') as HTMLButtonElement;
  const clearBtn = document.getElementById('clear-btn') as HTMLButtonElement;
  const progressSection = document.getElementById('progress-section') as HTMLDivElement;
  const resultSection = document.getElementById('result-section') as HTMLDivElement;
  const resultPages = document.getElementById('result-pages') as HTMLParagraphElement;
  const resultSize = document.getElementById('result-size') as HTMLParagraphElement;
  const downloadBtn = document.getElementById('download-btn') as HTMLButtonElement;

  // ── 工具函式 ─────────────────────────────────────────────
  function formatSize(bytes: number): string {
    if (bytes < 1024) return `${bytes} B`;
    if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
    return `${(bytes / 1024 / 1024).toFixed(2)} MB`;
  }

  function showError(msg: string) {
    errorText.textContent = msg;
    errorBanner.classList.remove('hidden');
    setTimeout(() => errorBanner.classList.add('hidden'), 6000);
  }

  function uid(): string {
    return Math.random().toString(36).slice(2, 9);
  }

  // ── 渲染檔案清單 ─────────────────────────────────────────
  function renderFileList() {
    fileListEl.innerHTML = '';

    if (pdfEntries.length === 0) {
      fileListSection.classList.add('hidden');
      resultSection.classList.add('hidden');
      mergedBlob = null;
      return;
    }

    fileListSection.classList.remove('hidden');
    fileCount.textContent = `（${pdfEntries.length} 個）`;

    pdfEntries.forEach((entry) => {
      const li = document.createElement('li');
      li.className =
        'flex items-center gap-3 bg-white rounded-xl border border-gray-200 px-4 py-3 cursor-grab active:cursor-grabbing select-none';
      li.draggable = true;
      li.dataset.id = entry.id;

      li.innerHTML = `
        <span class="text-gray-300 shrink-0 text-lg" aria-hidden="true">⠿</span>
        <span class="text-lg shrink-0">📄</span>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-medium text-gray-900 truncate">${entry.file.name}</p>
          <p class="text-xs text-gray-400">${entry.pageCount} 頁・${formatSize(entry.file.size)}</p>
        </div>
        <button
          class="remove-btn shrink-0 text-xs text-red-500 hover:text-red-700 hover:bg-red-50 px-2 py-1 rounded-lg transition-colors"
          data-id="${entry.id}"
          aria-label="移除 ${entry.file.name}"
        >
          移除
        </button>
      `;

      // DnD 排序
      li.addEventListener('dragstart', (e) => {
        dragSrcId = entry.id;
        li.classList.add('opacity-50');
        e.dataTransfer!.effectAllowed = 'move';
      });
      li.addEventListener('dragend', () => {
        dragSrcId = null;
        li.classList.remove('opacity-50');
        document.querySelectorAll('#file-list li').forEach((el) =>
          el.classList.remove('border-blue-400', 'border-2')
        );
      });
      li.addEventListener('dragover', (e) => {
        e.preventDefault();
        e.dataTransfer!.dropEffect = 'move';
        li.classList.add('border-blue-400', 'border-2');
      });
      li.addEventListener('dragleave', () => {
        li.classList.remove('border-blue-400', 'border-2');
      });
      li.addEventListener('drop', (e) => {
        e.preventDefault();
        li.classList.remove('border-blue-400', 'border-2');
        if (!dragSrcId || dragSrcId === entry.id) return;
        const srcIdx = pdfEntries.findIndex((x) => x.id === dragSrcId);
        const dstIdx = pdfEntries.findIndex((x) => x.id === entry.id);
        if (srcIdx === -1 || dstIdx === -1) return;
        const [moved] = pdfEntries.splice(srcIdx, 1);
        pdfEntries.splice(dstIdx, 0, moved);
        // 清除上次合併結果，因為順序改了
        mergedBlob = null;
        resultSection.classList.add('hidden');
        renderFileList();
      });

      // 移除按鈕
      li.querySelector<HTMLButtonElement>('.remove-btn')!.addEventListener('click', () => {
        pdfEntries = pdfEntries.filter((x) => x.id !== entry.id);
        mergedBlob = null;
        resultSection.classList.add('hidden');
        renderFileList();
      });

      fileListEl.appendChild(li);
    });
  }

  // ── 讀取 PDF 頁數 ────────────────────────────────────────
  async function readPdfPageCount(file: File): Promise<number> {
    const buf = await file.arrayBuffer();
    try {
      const doc = await PDFDocument.load(buf, { ignoreEncryption: false });
      return doc.getPageCount();
    } catch {
      throw new Error(`「${file.name}」無法讀取，可能已加密或損壞。`);
    }
  }

  // ── 加入檔案 ─────────────────────────────────────────────
  async function addFiles(files: FileList | File[]) {
    const fileArray = Array.from(files);

    const pdfs = fileArray.filter(
      (f) => f.type === 'application/pdf' || f.name.toLowerCase().endsWith('.pdf')
    );
    const nonPdf = fileArray.filter(
      (f) => f.type !== 'application/pdf' && !f.name.toLowerCase().endsWith('.pdf')
    );

    if (nonPdf.length > 0) {
      showError(`${nonPdf.length} 個檔案不是 PDF，已略過：${nonPdf.map((f) => f.name).join('、')}`);
    }

    const tooBig = pdfs.filter((f) => f.size > 100 * 1024 * 1024);
    if (tooBig.length > 0) {
      showError(`${tooBig.map((f) => f.name).join('、')} 超過 100 MB 上限，已略過。`);
    }
    const validPdfs = pdfs.filter((f) => f.size <= 100 * 1024 * 1024);

    const remaining = 20 - pdfEntries.length;
    if (validPdfs.length > remaining) {
      showError(`最多 20 個 PDF，已略過後面 ${validPdfs.length - remaining} 個。`);
      validPdfs.splice(remaining);
    }

    if (validPdfs.length === 0) return;

    // 讀取頁數
    for (const file of validPdfs) {
      try {
        const pageCount = await readPdfPageCount(file);
        pdfEntries.push({ file, pageCount, id: uid() });
      } catch (err) {
        showError((err as Error).message);
      }
    }

    mergedBlob = null;
    resultSection.classList.add('hidden');
    renderFileList();
  }

  // ── Dropzone 事件 ────────────────────────────────────────
  dropzone.addEventListener('dragover', (e) => {
    e.preventDefault();
    dropzone.classList.add('bg-blue-100', 'border-blue-500');
  });
  dropzone.addEventListener('dragleave', () => {
    dropzone.classList.remove('bg-blue-100', 'border-blue-500');
  });
  dropzone.addEventListener('drop', (e) => {
    e.preventDefault();
    dropzone.classList.remove('bg-blue-100', 'border-blue-500');
    if (e.dataTransfer?.files) addFiles(e.dataTransfer.files);
  });
  dropzone.addEventListener('keydown', (e) => {
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault();
      fileInput.click();
    }
  });
  fileInput.addEventListener('change', () => {
    if (fileInput.files) addFiles(fileInput.files);
    fileInput.value = '';
  });

  // ── 合併 PDF ─────────────────────────────────────────────
  mergeBtn.addEventListener('click', async () => {
    if (pdfEntries.length < 1) return;

    mergeBtn.disabled = true;
    progressSection.classList.remove('hidden');
    resultSection.classList.add('hidden');
    errorBanner.classList.add('hidden');

    try {
      const compress = compressCheckbox.checked;
      const merged = await PDFDocument.create();

      for (const entry of pdfEntries) {
        const buf = await entry.file.arrayBuffer();
        let srcDoc: PDFDocument;
        try {
          srcDoc = await PDFDocument.load(buf);
        } catch {
          throw new Error(`「${entry.file.name}」無法讀取，可能已加密或損壞。`);
        }
        const pages = await merged.copyPages(srcDoc, srcDoc.getPageIndices());
        pages.forEach((p) => merged.addPage(p));
      }

      const pdfBytes = await merged.save({ useObjectStreams: compress });
      mergedBlob = new Blob([pdfBytes], { type: 'application/pdf' });

      resultPages.textContent = String(merged.getPageCount());
      resultSize.textContent = formatSize(mergedBlob.size);
      resultSection.classList.remove('hidden');
    } catch (err) {
      showError((err as Error).message || '合併失敗，請確認所有 PDF 是否損壞或加密。');
    } finally {
      mergeBtn.disabled = false;
      progressSection.classList.add('hidden');
    }
  });

  // ── 下載 ─────────────────────────────────────────────────
  downloadBtn.addEventListener('click', () => {
    if (!mergedBlob) return;
    const url = URL.createObjectURL(mergedBlob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'merged.pdf';
    a.click();
    URL.revokeObjectURL(url);
  });

  // ── 清除全部 ─────────────────────────────────────────────
  clearBtn.addEventListener('click', () => {
    pdfEntries = [];
    mergedBlob = null;
    fileInput.value = '';
    fileListSection.classList.add('hidden');
    resultSection.classList.add('hidden');
    progressSection.classList.add('hidden');
    errorBanner.classList.add('hidden');
    fileListEl.innerHTML = '';
  });
</script>

---
interface Props {
  accept?: string;
  multiple?: boolean;
  maxSizeMB?: number;
  hint?: string;
  hintEn?: string;
  inputId?: string;
}

const {
  accept = '*/*',
  multiple = false,
  maxSizeMB = 100,
  hint = '拖曳檔案到此處，或點擊選擇檔案',
  hintEn = 'Drag & drop files here, or click to select',
  inputId = 'file-input',
} = Astro.props;

const acceptLabel = accept === '*/*' ? '所有格式' : accept;
const acceptLabelEn = accept === '*/*' ? 'All formats' : accept;
---

<div
  id="drop-zone"
  class="relative flex flex-col items-center justify-center gap-4 w-full min-h-48 rounded-2xl border-2 border-dashed border-blue-300 bg-blue-50 hover:bg-blue-100 hover:border-blue-400 transition-colors cursor-pointer p-8 text-center"
  role="button"
  tabindex="0"
  aria-label="File upload area"
>
  <div class="flex flex-col items-center gap-2 pointer-events-none">
    <span class="text-5xl">📂</span>
    <p class="text-base font-medium text-blue-700">
      <span class="lang-zh">{hint}</span>
      <span class="lang-en">{hintEn}</span>
    </p>
    <p class="text-sm text-gray-500">
      <span class="lang-zh">
        支援 {acceptLabel}{multiple ? '，可選擇多個檔案' : ''}
      </span>
      <span class="lang-en">
        Supports {acceptLabelEn}{multiple ? ', multiple files' : ''}
      </span>
    </p>
    <p class="text-xs text-gray-400">
      <span class="lang-zh">最大 {maxSizeMB} MB</span>
      <span class="lang-en">Max {maxSizeMB} MB</span>
    </p>
  </div>

  <div class="flex items-center gap-1.5 text-xs text-emerald-700 bg-emerald-50 border border-emerald-200 rounded-full px-3 py-1 pointer-events-none">
    <span>🔒</span>
    <span>
      <span class="lang-zh">檔案僅在您的瀏覽器中處理，不會上傳至任何伺服器</span>
      <span class="lang-en">Files processed in your browser only, never uploaded</span>
    </span>
  </div>

  <input
    id={inputId}
    type="file"
    accept={accept}
    multiple={multiple}
    class="absolute inset-0 w-full h-full opacity-0 cursor-pointer"
    aria-hidden="true"
  />
</div>

<div id="file-list" class="hidden mt-4 space-y-2" aria-live="polite"></div>

<script>
  const dropZone = document.getElementById('drop-zone') as HTMLDivElement;
  const fileInput = dropZone?.querySelector('input[type="file"]') as HTMLInputElement;
  const fileList = document.getElementById('file-list') as HTMLDivElement;

  if (dropZone && fileInput && fileList) {
    dropZone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropZone.classList.add('bg-blue-100', 'border-blue-500');
    });

    dropZone.addEventListener('dragleave', () => {
      dropZone.classList.remove('bg-blue-100', 'border-blue-500');
    });

    dropZone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropZone.classList.remove('bg-blue-100', 'border-blue-500');
      if (e.dataTransfer?.files) {
        showFiles(e.dataTransfer.files);
        dropZone.dispatchEvent(new CustomEvent('files-selected', { detail: e.dataTransfer.files, bubbles: true }));
      }
    });

    dropZone.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        fileInput.click();
      }
    });

    fileInput.addEventListener('change', () => {
      if (fileInput.files) {
        showFiles(fileInput.files);
        dropZone.dispatchEvent(new CustomEvent('files-selected', { detail: fileInput.files, bubbles: true }));
      }
    });

    function showFiles(files: FileList) {
      fileList.innerHTML = '';
      fileList.classList.remove('hidden');
      Array.from(files).forEach((file) => {
        const item = document.createElement('div');
        item.className = 'flex items-center gap-3 bg-white rounded-lg border border-gray-200 px-4 py-2 text-sm';
        const sizeMB = (file.size / 1024 / 1024).toFixed(2);
        item.innerHTML = `
          <span class="text-lg">📄</span>
          <span class="flex-1 truncate font-medium text-gray-800">${file.name}</span>
          <span class="text-gray-400 shrink-0">${sizeMB} MB</span>
        `;
        fileList.appendChild(item);
      });
    }
  }
</script>
